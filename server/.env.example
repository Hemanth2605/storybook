# Copy this file to `.env` and fill in real values.
# If SMTP_USER / SMTP_PASS are left blank, the server automatically falls back
# to a Nodemailer "Ethereal" test account: mail is NOT delivered to a real
# inbox, but the console prints a preview URL so you can verify the flow.

# --- Where requests are sent ---
MAIL_TO=hemanth.mareedu8@gmail.com
MAIL_FROM=Component Requests <no-reply@example.com>

# --- SMTP transport (e.g. Gmail) ---
# For Gmail: enable 2-Step Verification, then create an App Password
# (Google Account -> Security -> App passwords) and paste the 16 chars below.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# --- Server ---
PORT=4000
# Public base URL used to build the Approve/Reject links inside the email.
PUBLIC_BASE_URL=http://localhost:4000
